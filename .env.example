# ---- LLM provider (configurable) ----
# Used by language-heavy agents (Intake, Label, Recall summarization, Risk, Response).
# Choose one provider; all use an OpenAI-compatible chat API. Submission can
# claim AI/ML API — just set LLM_PROVIDER=aiml. If the selected provider's key
# is blank, agents fall back to deterministic logic so the demo still runs.
LLM_PROVIDER=aiml   # aiml | openai | gemini

# AI/ML API (OpenAI-compatible)
AIML_API_KEY=
AIML_API_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (AI Studio) — via its OpenAI-compatible endpoint
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional hard overrides (win over the provider presets above)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# ---- Band (real platform) ----
# BAND_API_KEY is your human/owner key (used by the Streamlit recall-manager UI).
BAND_API_KEY=
BAND_API_BASE_URL=https://app.band.ai/api/v1
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# Your Band user UUID, so agents can @mention the human recall manager.
BAND_OWNER_USER_ID=
# Display name + handle for the human recall manager in the room.
BAND_OWNER_NAME=Recall Manager
BAND_OWNER_HANDLE=recall_manager
# Written by scripts/register_agents.py (agent ids + per-agent API keys).
BAND_AGENT_KEYS_FILE=agents.json

# ---- openFDA ----
# Cache is used only as a fallback after a successful live fetch.
USE_CACHED_PUBLIC_DATA=true
OPENFDA_BASE_URL=https://api.fda.gov/food/enforcement.json
