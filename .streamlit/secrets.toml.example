# SafetySignal Desk — Streamlit Community Cloud secrets template.
# In your local checkout, `.streamlit/secrets.toml` is generated for you with
# real values (and is gitignored). On Streamlit Cloud, paste the equivalent
# into: Manage app → Settings → Secrets.

BAND_API_KEY = "band_u_..."
BAND_API_BASE_URL = "https://app.band.ai/api/v1"
BAND_WS_URL = "wss://app.band.ai/api/v1/socket/websocket"
BAND_OWNER_USER_ID = "your-band-user-uuid"
BAND_OWNER_NAME = "Recall Manager"
BAND_OWNER_HANDLE = "recall_manager"

# LLM (optional — blank = deterministic fallback).
LLM_PROVIDER = "aiml"   # aiml | openai | gemini
OPENAI_API_KEY = ""
GEMINI_API_KEY = ""
AIML_API_KEY = ""

USE_CACHED_PUBLIC_DATA = "true"
OPENFDA_BASE_URL = "https://api.fda.gov/food/enforcement.json"

# Registered agent ids + keys as a single-line JSON string
# (the contents of agents.json, which is gitignored).
BAND_AGENTS_JSON = '{"complaint_intake":{"agent_id":"...","api_key":"...","name":"Complaint Intake Agent","handle":"..."}, "...": {}}'
